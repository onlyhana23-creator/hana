{
  "installCommand": "python3 -m venv .venv && .venv/bin/pip install -r requirements.txt",
  "buildCommand": ".venv/bin/pip install -r requirements.txt",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.py": {
      "includeFiles": "*.xlsx"
    }
  }
}
